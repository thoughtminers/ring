{
  "name": "ring",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint -w @thoughtminers/ring-client-api",
    "lint:fix": "npm run lint -w @thoughtminers/ring-client-api -- --fix",
    "test:watch": "npm run test:watch -w ring-client-api",
    "example": "npm run build -w ring-client-api && DEBUG=ring node --experimental-strip-types ./packages/examples/example.ts",
    "api-example": "npm run build -w ring-client-api && DEBUG=ring node --experimental-strip-types ./packages/examples/api-example.ts",
    "auth-cli": "npm run build -w ring-client-api && ./packages/ring-client-api/lib/ring-auth-cli.js",
    "device-data-cli": "npm run build -w ring-client-api && ./packages/ring-client-api/lib/ring-device-data-cli.js"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@11.8.0"
}
