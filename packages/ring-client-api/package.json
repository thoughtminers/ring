    "rxjs": "^7.8.2",
    "systeminformation": "^5.30.8",
    "undici": "^7.19.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/debug": "4.1.12",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "25.1.0",
    "@types/uuid": "11.0.0",
    "@types/ws": "^8.18.1",
    "eslint-config-shared": "*",
    "msw": "^2.12.7",
    "tsconfig": "*",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
